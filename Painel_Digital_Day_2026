<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Painel de Inscrições</title>

  <style>
    :root{
      --bg0:#070A12;
      --bg1:#0A1020;
      --stroke:rgba(255,255,255,.10);
      --text:rgba(255,255,255,.92);
      --muted:rgba(255,255,255,.60);

      --pink:#FF3EA5;
      --yellow:#FFC233;

      --radius:18px;
      --shadow: 0 18px 60px rgba(0,0,0,.45);
    }

    *{ box-sizing:border-box; }
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Noto Sans", "Helvetica Neue", sans-serif;
      background:
        radial-gradient(1200px 600px at 20% 0%, rgba(255,62,165,.14), transparent 60%),
        radial-gradient(900px 500px at 80% 10%, rgba(255,194,51,.12), transparent 55%),
        linear-gradient(180deg, var(--bg0), var(--bg1));
      color:var(--text);
      min-height:100vh;
    }

    .topbar{
      height:72px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:0 28px;
      border-bottom:1px solid rgba(255,255,255,.06);
      background: rgba(0,0,0,.12);
      backdrop-filter: blur(10px);
    }
    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      letter-spacing:.04em;
      font-weight:800;
      text-transform:uppercase;
      font-size:16px;
    }
    .brand .logo{
      width:18px;height:18px;border-radius:6px;
      background: linear-gradient(135deg, rgba(255,62,165,.9), rgba(255,194,51,.9));
      box-shadow: 0 10px 30px rgba(255,62,165,.15);
    }
    .status{
      display:flex;
      align-items:center;
      gap:10px;
      color:var(--muted);
      font-weight:700;
      font-size:13px;
    }
    .dot{
      width:8px;height:8px;border-radius:999px;
      background:#2BE06D;
      box-shadow:0 0 0 6px rgba(43,224,109,.12);
    }
    .clock{
      font-variant-numeric: tabular-nums;
      color:rgba(255,255,255,.78);
      font-weight:800;
      letter-spacing:.02em;
    }

    .wrap{
      max-width:1100px;
      margin:0 auto;
      padding:28px;
    }
    .grid{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap:22px;
      margin-top:18px;
    }
    @media (max-width: 920px){
      .grid{ grid-template-columns: 1fr; }
    }

    .card{
      position:relative;
      border-radius: var(--radius);
      background: linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.02));
      border:1px solid rgba(255,255,255,.10);
      box-shadow: var(--shadow);
      overflow:hidden;
      padding:22px 22px 18px 22px;
      min-height: 220px;
    }
    .card::before{
      content:"";
      position:absolute; inset:-2px;
      background:
        radial-gradient(600px 220px at 20% 0%, rgba(255,62,165,.14), transparent 60%),
        radial-gradient(520px 240px at 85% 0%, rgba(255,194,51,.10), transparent 60%);
      pointer-events:none;
      opacity:.9;
    }
    .card > *{ position:relative; }

    .head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      margin-bottom:10px;
    }
    .title{
      display:flex;
      align-items:center;
      gap:10px;
      font-weight:900;
      letter-spacing:.03em;
      text-transform:uppercase;
      color:rgba(255,255,255,.80);
      font-size:16px;
    }
    .badge{
      width:28px;height:28px;border-radius:10px;
      display:grid;place-items:center;
      background: rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.10);
    }

    .valueRow{
      display:flex;
      align-items:flex-end;
      justify-content:space-between;
      gap:10px;
      margin: 14px 0 12px;
    }
    .value{
      font-size:64px;
      line-height:1;
      font-weight:950;
      letter-spacing:-.02em;
      font-variant-numeric: tabular-nums;
    }
    .metaPill{
      color:var(--muted);
      font-weight:800;
      font-size:13px;
      background: rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.08);
      border-radius:999px;
      padding:8px 10px;
      white-space:nowrap;
    }

    .progressLine{ margin-top:14px; }
    .progressTop{
      display:flex;
      justify-content:space-between;
      align-items:center;
      color:var(--muted);
      font-size:13px;
      font-weight:800;
      margin-bottom:10px;
    }
    .bar{
      height:14px;
      border-radius:999px;
      background: rgba(255,255,255,.08);
      overflow:hidden;
      border:1px solid rgba(255,255,255,.08);
    }
    .fill{
      height:100%;
      width:0%;
      border-radius:999px;
      transform: translateZ(0);
      transition: width .6s ease;
    }
    .updated{
      margin-top:14px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      color:rgba(255,255,255,.55);
      font-size:12px;
      font-weight:800;
    }
    .updated .left{
      display:flex; align-items:center; gap:8px;
    }
    .updated .clockIcon{
      width:18px;height:18px;border-radius:9px;
      display:grid;place-items:center;
      background: rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.08);
    }

    .pink .value{ color:var(--pink); }
    .pink .fill{ background: linear-gradient(90deg, rgba(255,62,165,.95), rgba(255,62,165,.55)); }

    .yellow .value{ color:var(--yellow); }
    .yellow .fill{ background: linear-gradient(90deg, rgba(255,194,51,.95), rgba(255,194,51,.55)); }

    .hint{ margin-top:10px; color: rgba(255,255,255,.55); font-size:12px; font-weight:800; }
    .error{ color: rgba(255,80,80,.88); }
  </style>
</head>

<body>
  <div class="topbar">
    <div class="brand">
      <div class="logo"></div>
      PAINEL DE INSCRIÇÕES - ITALO LIMA
    </div>

    <div class="status">
      <span class="dot"></span>
      <span>AO VIVO</span>
    </div>

    <div class="clock" id="clock">--:--:--</div>
  </div>

  <div class="wrap">
    <div class="grid">
      <!-- Sebrae -->
      <section class="card pink">
        <div class="head">
          <div class="title">
            <span class="badge">🚀</span>
            SEBRAE DELAS 2026
          </div>
        </div>

        <div class="valueRow">
          <div class="value" id="sebrae-value">--</div>
          <div class="metaPill" id="sebrae-meta">Meta: -- / --</div>
        </div>

        <div class="progressLine">
          <div class="progressTop">
            <span></span>
            <span id="sebrae-pct">--%</span>
          </div>
          <div class="bar"><div class="fill" id="sebrae-fill"></div></div>
        </div>

        <div class="updated">
          <div class="left">
            <div class="clockIcon">🕒</div>
            <span id="sebrae-updated">Atualizado: --</span>
          </div>
          <span id="sebrae-ago">—</span>
        </div>

        <div class="hint" id="sebrae-hint"></div>
      </section>

      <!-- Amazonas -->
      <section class="card yellow">
        <div class="head">
          <div class="title">
            <span class="badge">🛢️</span>
            AMAZONAS ÓLEO, GÁS E ENERGIA
          </div>
        </div>

        <div class="valueRow">
          <div class="value" id="amz-value">--</div>
          <div class="metaPill" id="amz-meta">Meta: -- / --</div>
        </div>

        <div class="progressLine">
          <div class="progressTop">
            <span></span>
            <span id="amz-pct">--%</span>
          </div>
          <div class="bar"><div class="fill" id="amz-fill"></div></div>
        </div>

        <div class="updated">
          <div class="left">
            <div class="clockIcon">🕒</div>
            <span id="amz-updated">Atualizado: --</span>
          </div>
          <span id="amz-ago">—</span>
        </div>

        <div class="hint" id="amz-hint"></div>
      </section>
    </div>
  </div>

  <script>
    /**
     * ✅ Seu webhook retorna APENAS:
     * {"Total_de_inscritos":224}
     *
     * Então, para ter 2 eventos no painel, você precisa de:
     * - 2 URLs (uma para Sebrae e outra para Amazonas)
     *   OU
     * - 1 URL com parâmetro (ex.: ?evento=sebrae / ?evento=amazonas)
     *
     * Aqui eu deixei pronto para 2 URLs (mais simples).
     */

    // =========================
    // 1) COLE AS URL(s) DO N8N AQUI
    // =========================
    const WEBHOOK_SEBRAE   = "https://n8n.srv1064194.hstgr.cloud/webhook/Webhook_obter_numero_de_inscritos";
    const WEBHOOK_AMAZONAS = "https://n8n.srv1064194.hstgr.cloud/webhook/2d48ad60-3ec6-4baf-88a9-86268427cf2b";

    // =========================
    // 2) META de cada evento (fixa no HTML)
    // =========================
    const META_SEBRAE = 900;
    const META_AMZ    = 3000;

    // =========================
    // 3) Intervalo de atualização (em segundos)
    // =========================
    const REFRESH_SECONDS = 15;

    const $ = (id) => document.getElementById(id);

    // Guardamos o "momento do último fetch" para calcular tempo decorrido no próprio HTML
    const lastUpdated = {
      sebrae: null,
      amz: null
    };

    function formatNumber(n){
      if (n === null || n === undefined || Number.isNaN(Number(n))) return "--";
      return new Intl.NumberFormat("pt-BR").format(Number(n));
    }

    function calcPct(value, goal){
      const v = Number(value), g = Number(goal);
      if (!g || Number.isNaN(v) || Number.isNaN(g)) return 0;
      return Math.max(0, Math.min(100, (v / g) * 100));
    }

    function formatDateTime(d){
      return d.toLocaleString("pt-BR");
    }

    function humanizeAgo(ms){
      if (ms < 0) ms = 0;
      const s = Math.floor(ms / 1000);
      if (s < 5) return "agora mesmo";
      if (s < 60) return `há ${s}s`;
      const m = Math.floor(s / 60);
      if (m < 60) return `há ${m}min`;
      const h = Math.floor(m / 60);
      if (h < 24) return `há ${h}h`;
      const d = Math.floor(h / 24);
      return `há ${d}d`;
    }

    function setHint(prefix, msg, isError=false){
      const el = $(`${prefix}-hint`);
      el.textContent = msg || "";
      el.classList.toggle("error", !!isError);
    }

    function updateCard(prefix, inscritos, meta){
      const pct = calcPct(inscritos, meta);
      $(`${prefix}-value`).textContent = formatNumber(inscritos);
      $(`${prefix}-meta`).textContent = `Meta: ${formatNumber(inscritos)} / ${formatNumber(meta)}`;
      $(`${prefix}-pct`).textContent = `${pct.toFixed(1)}%`;
      $(`${prefix}-fill`).style.width = `${pct}%`;

      const now = new Date();
      lastUpdated[prefix === "sebrae" ? "sebrae" : "amz"] = now;

      $(`${prefix}-updated`).textContent = `Atualizado: ${formatDateTime(now)}`;
      $(`${prefix}-ago`).textContent = "agora mesmo";
    }

    async function fetchTotal(url){
      const res = await fetch(url, { method: "GET" });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const json = await res.json();
      const total = Number(json?.Total_de_inscritos);
      if (Number.isNaN(total)) throw new Error("JSON inválido (Total_de_inscritos não é número)");
      return total;
    }

    async function refresh(){
      // Sebrae
      try{
        if (!WEBHOOK_SEBRAE || WEBHOOK_SEBRAE.includes("COLE_AQUI")){
          setHint("sebrae","Cole a URL do webhook do Sebrae (modo demo).");
          updateCard("sebrae", 806, META_SEBRAE);
        } else {
          setHint("sebrae","Atualizando…");
          const total = await fetchTotal(WEBHOOK_SEBRAE);
          updateCard("sebrae", total, META_SEBRAE);
          setHint("sebrae","");
        }
      } catch(e){
        setHint("sebrae", `Erro ao buscar dados: ${e.message}`, true);
      }

      // Amazonas
      try{
        if (!WEBHOOK_AMAZONAS || WEBHOOK_AMAZONAS.includes("COLE_AQUI")){
          setHint("amz","Cole a URL do webhook do Amazonas (modo demo).");
          updateCard("amz", 524, META_AMZ);
        } else {
          setHint("amz","Atualizando…");
          const total = await fetchTotal(WEBHOOK_AMAZONAS);
          updateCard("amz", total, META_AMZ);
          setHint("amz","");
        }
      } catch(e){
        setHint("amz", `Erro ao buscar dados: ${e.message}`, true);
      }
    }

    // Relógio no topo
    function tickClock(){
      const now = new Date();
      const hh = String(now.getHours()).padStart(2,"0");
      const mm = String(now.getMinutes()).padStart(2,"0");
      const ss = String(now.getSeconds()).padStart(2,"0");
      $("clock").textContent = `${hh}:${mm}:${ss}`;
    }

    // Atualiza o "há X" sem precisar refazer fetch
    function tickAgo(){
      const now = Date.now();

      if (lastUpdated.sebrae){
        const ms = now - lastUpdated.sebrae.getTime();
        $("sebrae-ago").textContent = humanizeAgo(ms);
      }
      if (lastUpdated.amz){
        const ms = now - lastUpdated.amz.getTime();
        $("amz-ago").textContent = humanizeAgo(ms);
      }
    }

    tickClock();
    setInterval(tickClock, 1000);

    tickAgo();
    setInterval(tickAgo, 1000);

    refresh();
    setInterval(refresh, REFRESH_SECONDS * 1000);
  </script>
</body>
</html>

